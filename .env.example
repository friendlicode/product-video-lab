# Product Video Lab environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored via the "*.local" pattern.

# Supabase project URL, e.g. https://abcdefghij.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (safe to ship to the browser).
# Found in Supabase dashboard: Project Settings > API > Project API keys > anon public.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI API key.
#
# Production deployment uses "Option 3": leave this BLANK in Vercel.
# Each user pastes their own OpenAI key into the Settings page after logging in.
# The key is stored in localStorage (client-side only) under `vpl_settings`.
#
# For local development you can set a personal key here so you do not have to
# paste it every time you clear browser storage.
VITE_OPENAI_API_KEY=
